{
	order webdav before file_server
	auto_https off
	admin off
	log {
		# logging increases mem usage significantly
		# output stdout
		output {$CADDY_LOG_OUTPUT:discard}
		level  {$CADDY_LOG_LEVEL:INFO}
		format console
	}
	storage file_system {
		root /home/caddy/caddy-data
	}
}

:80 {
	@get method GET
	root * /home/caddy/caddy-media
	route {
		header {
			-Server
		}
		request_body {
			max_size {$CADDY_REQUEST_BODY_MAX_SIZE:1gb}
		}
		file_server @get browse
		webdav
	}
	basic_auth {
		{$BASIC_AUTH_USERNAME} {$BASIC_AUTH_PASSWORD}
	}
}
